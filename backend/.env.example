# ── ArthaAI Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values

# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Flask settings
FLASK_DEBUG=true
SECRET_KEY=change_this_in_production_abc123
JWT_SECRET_KEY=change_this_jwt_secret_xyz789

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=arthaai@2025

# Port (default 5000)
PORT=5000
